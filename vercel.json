{
  "version": 2,
  "cleanUrls": true,
  "crons": [
    {
      "path": "/api/cron-morning-reminder",
      "schedule": "0 13 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
